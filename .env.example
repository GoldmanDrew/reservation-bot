# Optional: password-protect the entire app when deployed publicly
APP_PASSWORD=

# Persistent data directory (use /data on Render with a mounted disk)
DATA_DIR=./data

# Pre-seed Resy credentials (optional — can also connect via Settings UI)
RESY_EMAIL=
RESY_PASSWORD=
RESY_API_KEY=
RESY_AUTH_TOKEN=

# Pre-seed OpenTable session (required for OpenTable snipes)
OPENTABLE_COOKIES=
OPENTABLE_CSRF_TOKEN=

# Server port (Render sets this automatically)
PORT=3000
